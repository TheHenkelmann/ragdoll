{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "containerAppName": {
      "type": "string",
      "defaultValue": "ragdoll"
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "ragdoll-env"
    },
    "storageAccountName": {
      "type": "string",
      "defaultValue": "[concat('ragdoll', uniqueString(resourceGroup().id))]"
    },
    "fileShareName": {
      "type": "string",
      "defaultValue": "ragdoll-data"
    },
    "imageName": {
      "type": "string",
      "defaultValue": "ghcr.io/thehenkelmann/ragdoll:latest"
    },
    "secretOverride": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional override for RAGDOLL_SECRET. Leave empty to auto-generate an ephemeral random secret (not stored for you)."
      }
    }
  },
  "variables": {
    "generatedSecret": "[concat(replace(guid(), '-', ''), replace(guid(), '-', ''), replace(guid(), '-', ''))]",
    "ragdollSecret": "[if(empty(parameters('secretOverride')), variables('generatedSecret'), parameters('secretOverride'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2"
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', parameters('storageAccountName'), parameters('fileShareName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ],
      "properties": { "shareQuota": 100 }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[parameters('environmentName')]",
      "location": "[parameters('location')]",
      "properties": {
        "workloadProfiles": [
          { "name": "Consumption", "workloadProfileType": "Consumption" }
        ]
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/ragdoll-storage', parameters('environmentName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ],
      "properties": {
        "azureFile": {
          "accountName": "[parameters('storageAccountName')]",
          "shareName": "[parameters('fileShareName')]",
          "accessMode": "ReadWrite",
          "accountKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-01-01').keys[0].value]"
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]",
        "[resourceId('Microsoft.App/managedEnvironments/storages', parameters('environmentName'), 'ragdoll-storage')]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "auto"
          },
          "secrets": [
            { "name": "ragdoll-secret", "value": "[variables('ragdollSecret')]" }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "ragdoll",
              "image": "[parameters('imageName')]",
              "resources": { "cpu": 2.0, "memory": "4Gi" },
              "env": [
                { "name": "RAGDOLL_DATA_DIR", "value": "/data" },
                { "name": "RAGDOLL_SECRET", "secretRef": "ragdoll-secret" }
              ],
              "volumeMounts": [
                { "volumeName": "data", "mountPath": "/data" }
              ]
            }
          ],
          "scale": { "minReplicas": 1, "maxReplicas": 1 },
          "volumes": [
            {
              "name": "data",
              "storageType": "AzureFile",
              "storageName": "ragdoll-storage"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "containerAppName": {
      "type": "string",
      "value": "[parameters('containerAppName')]"
    }
  }
}
