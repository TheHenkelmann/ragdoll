# Required
RAGDOLL_DATA_DIR=/data
RAGDOLL_JWT_SECRET=change-me-in-production

# Optional auth bootstrap
# RAGDOLL_SUPERADMIN_EMAIL=admin@ragdoll.ai
# RAGDOLL_SUPERADMIN_PW=

# Optional path overrides
# RAGDOLL_DB_PATH=/data/db/ragdoll.db
# RAGDOLL_MODEL_CACHE_DIR=/data/models
# RAGDOLL_STAGING_DIR=/data/staging

# Models (dim 1024 whitelist only in v1)
RAGDOLL_EMBEDDING_MODEL=BAAI/bge-m3
RAGDOLL_EMBEDDING_DIM=1024
RAGDOLL_DISTANCE_METRIC=cosine
RAGDOLL_PORT=8080

# ONNX runtime
RAGDOLL_ONNX_NUM_THREADS=4

# Hugging Face (first start downloads models unless pre-mounted)
# RAGDOLL_HF_TOKEN=
# RAGDOLL_HF_HUB_OFFLINE=0

# Worker
RAGDOLL_WORKER_POLL_INTERVAL_MS=1000
RAGDOLL_JOB_LEASE_SECONDS=300
RAGDOLL_MAX_ATTEMPTS=3

# Logging
RUST_LOG=info,ragdoll=debug
